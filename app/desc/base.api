syntax = "v2"

info (
	title:   "统一返回"
	desc:    "统一返回 数据格式"
	author:  "liubiao"
	version: "v1.0.0"
)

// ==================== 通用类型 ====================
// ---- 类型化响应基础 ----
type BaseResp {
	Code      int  `json:"code"`
	Msg       string `json:"msg"`
	TraceId string `json:"traceId,omitempty"`
	TimestampMs int64 `json:"timestampMs"`
}

type BasePageReq {
    Page     int `form:"page"`
    PageSize int `form:"pageSize"`
}


